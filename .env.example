# TeamMCP Server Configuration

# TeamMCP home directory (REQUIRED)
# All data (database, uploads, screenshots) lives here.
# Example: C:/Users/YOU/Desktop/teammcp
TEAMMCP_HOME=/path/to/teammcp-data

# Path to the agents workspace directory (REQUIRED)
# Example: C:/Users/YOU/Desktop/agents
AGENTS_BASE_DIR=/path/to/agents

# Server port (default: 3100)
# TEAMMCP_PORT=3100

# Registration secret (optional, leave empty to allow open registration)
# TEAMMCP_REGISTER_SECRET=

# Auto-restart crashed agents (set to '0' to disable, default: enabled)
# TEAMMCP_AUTO_RESTART=1

# Screenshots directory (default: ~/.teammcp/screenshots)
# SCREENSHOTS_DIR=/path/to/screenshots
